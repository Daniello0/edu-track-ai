PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=edu_track_ai

# Secret for signing/verifying API access JWTs (generate yourself, e.g. openssl rand -base64 32)
JWT_ACCESS_SECRET=your-access-secret
# Not used yet — refresh tokens are opaque strings hashed in DB (see docs/schemas-design.md)
JWT_REFRESH_SECRET=your-refresh-secret

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Path to Firebase Admin service account JSON (NOT the frontend firebaseConfig)
# Copy config/firebase-service-account.example.json → config/firebase-service-account.json and fill from Firebase Console
FIREBASE_CREDENTIALS_PATH=./config/firebase-service-account.json

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile # llama-3.3-70b-versatile, llama-3.3-70b-instruct
